# Echoes local processing worker
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: skip the real safety scan during local dev
AUTO_PASS_SAFETY=false
HIVE_API_KEY=

# Paths
WORK_DIR=./work
POLL_INTERVAL_SECONDS=5

# Pipeline tuning
FRAMES_PER_SECOND=8
MAX_TRAIN_ITERATIONS=8000

# 4DGaussians (hustvl/4DGaussians) — clone the repo and point these at it
FOURDGS_REPO_DIR=./vendor/4DGaussians
FOURDGS_CONFIG=./vendor/4DGaussians/arguments/dynerf/default.py

# Optional observability — leave blank to disable.
SENTRY_DSN=
SENTRY_ENV=worker
SENTRY_TRACES_SAMPLE_RATE=0.1
